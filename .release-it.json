{
  "git": {
    "requireCleanWorkingDir": true,
    "commitMessage": "chore: release ${version}",
    "tagName": "v${version}",
    "push": false
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": false
  },
  "hooks": {
    "before:init": "npm run release:dry-run",
    "after:bump": "node scripts/sync-release-version.mjs ${version}"
  }
}
