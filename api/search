pose","tags":[],"type":"text","url":"/deployment/docker-compose#environment-variables","content":"Service log level. Accepted values are `silent`, `fatal`, `error`, `warn`, `info`, `debug`, and `trace`."},"98":{"id":"/deployment/docker-compose-53","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#environment-variables","content":"`PUBLIC_API_KEYS`"},"99":{"id":"/deployment/docker-compose-54","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#environment-variables","content":"for no-origin backend ingest"},"100":{"id":"/deployment/docker-compose-55","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#environment-variables","content":"empty"},"101":{"id":"/deployment/docker-compose-56","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#environment-variables","content":"Comma-separated API keys. No-origin backend requests require one of these keys; leave empty to disable no-origin backend ingest. Browser requests from allowed origins can omit `api_key`; provided keys are still validated. Include old and new keys during rotation."},"102":{"id":"/deployment/docker-compose-57","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#environment-variables","content":"`ALLOWED_ORIGINS`"},"103":{"id":"/deployment/docker-compose-58","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#environment-variables","content":"recommended"},"104":{"id":"/deployment/docker-compose-59","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#environment-variables","content":"empty"},"105":{"id":"/deployment/docker-compose-60","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#environment-variables","content":"Comma-separated browser origin