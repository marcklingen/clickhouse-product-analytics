tainer close to ClickHouse. Put it behind a TLS-terminating reverse proxy or load balancer. Browser applications talk to the public HTTPS ingest URL. Backend services can use the same public URL or a private network URL."},"64":{"id":"/deployment/docker-compose-19","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#production-shape","content":"Recommended production model:"},"65":{"id":"/deployment/docker-compose-20","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#production-shape","content":"one or more ingest service containers,"},"66":{"id":"/deployment/docker-compose-21","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#production-shape","content":"shared ClickHouse database on a supported stable or LTS ClickHouse release,"},"67":{"id":"/deployment/docker-compose-22","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#production-shape","content":"stable `PUBLIC_API_KEYS` when backend or no-origin requests are used,"},"68":{"id":"/deployment/docker-compose-23","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#production-shape","content":"explicit `ALLOWED_ORIGINS`,"},"69":{"id":"/deployment/docker-compose-24","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#production-shape","content":"`LOG_LEVEL=warn` or stricter for high-volume traffic,"},"70":{"id":"/deployment/docker-compose-25","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#production-shape","content":"migrations run manually before deploy,"},"71":{"id":"/deployment/docker-compose-26","page_id":"/deployment/docker-compose","tags":[],"type":"text","url":"/deployment/docker-compose#production-shape","content":"`MIGRATE_ON_START=false` or omitted in production."},"72":{"id":"/deploymen