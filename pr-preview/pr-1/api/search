k-stability","type":"heading","tags":[],"url":"/project/sdk-stability#improvements-applied","content":"Improvements Applied"},"566":{"id":"/project/sdk-stability-4","page_id":"/project/sdk-stability","type":"heading","tags":[],"url":"/project/sdk-stability#stability-gaps-to-watch","content":"Stability Gaps To Watch"},"567":{"id":"/project/sdk-stability-5","page_id":"/project/sdk-stability","type":"heading","tags":[],"url":"/project/sdk-stability#decision","content":"Decision"},"568":{"id":"/project/sdk-stability-6","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#sdk-stability-review","content":"The browser SDK is intentionally small. This review focuses on performance and stability patterns from mature browser analytics SDKs, not feature parity."},"569":{"id":"/project/sdk-stability-7","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#what-was-reviewed","content":"Mature open-source browser analytics SDK repository structure and package surfaces."},"570":{"id":"/project/sdk-stability-8","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#what-was-reviewed","content":"Retry queue declarations and release notes around retry queue fixes in established analytics SDKs."},"571":{"id":"/project/sdk-stability-9","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#what-was-reviewed","content":"Long-standing unload reliability discussions around `sendBeacon`."},"572":{"id":"/project/sdk-stability-10","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#what-was-reviewed","content":"This repo's SDK queue, transport, storage, autocapture, React wrapper, and E2E coverage."},"573":{"id":"/project/sdk-stability-11","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"Fetch requests use gzip with browser `CompressionStream` when available, and fall back to plain JSON if compression is unavailable or fails."},"574":{"id":"/project/sdk-stability-12","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"SendBeacon unload flushes remain uncompressed because browsers do not let callers attach arbitrary `content-encoding` headers to beacon bodies."},"575":{"id":"/project/sdk-stability-13","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"The E2E test now exercises SDK compression in addition to direct API gzip requests."},"576":{"id":"/project/sdk-stability-14","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"Event properties are sanitized before enqueueing so circular objects and `bigint` values do not crash capture or flush."},"577":{"id":"/project/sdk-stability-15","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"Permanent HTTP errors such as `401` are no longer retried, while `413` responses split a batch before retrying smaller chunks."},"578":{"id":"/project/sdk-stability-16","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"Concurrent flush calls are serialized, and unload flushes include queued retry batches."},"579":{"id":"/project/sdk-stability-17","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"The ingest service no longer logs every successful request by default, which matters for high-throughput browser batch ingestion."},"580":{"id":"/project/sdk-stability-18","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Area"},"581":{"id":"/project/sdk-stability-19","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Current state"},"582":{"id":"/project/sdk-stability-20","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Recommendation"},"583":{"id":"/project/sdk-stability-21","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Durable retry queue"},"584":{"id":"/project/sdk-stability-22","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Retries live in memory and are flushed on unload but are not persisted across reloads."},"585":{"id":"/project/sdk-stability-23","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Keep this for now because the repo scope is small. Add persistent retry storage only if customer apps show loss during flaky network or reload-heavy flows."},"586":{"id":"/project/sdk-stability-24","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Byte-aware batch splitting"},"587":{"id":"/project/sdk-stability-25","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"The SDK limits queue count and server body size, but it does not split batches by encoded byte size before sending."},"588":{"id":"/project/sdk-stability-26","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Add byte-size splitting before supporting very large property payloads or high `flushAt` values."},"589":{"id":"/project/sdk-stability-27","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Navigation-critical events"},"590":{"id":"/project/sdk-stability-28","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Pageleave uses best-effort `sendBeacon`, then fetch fallback if beacon rejects."},"591":{"id":"/project/sdk-stability-29","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"For form submissions or payment handoffs, call `flush()` before navigating when the event is business-critical."},"592":{"id":"/project/sdk-stability-30","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Cross-tab coordination"},"593":{"id":"/project/sdk-stability-31","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Each tab has its own in-memory queue and shared persisted identity state."},"594":{"id":"/project/sdk-stability-32","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Keep as-is until duplicate or ordering issues appear; cross-tab queue ownership adds complexity."},"595":{"id":"/project/sdk-stability-33","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Autocapture privacy"},"596":{"id":"/project/sdk-stability-34","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"The SDK denies obvious sensitive inputs and values, but autocapture remains opt-in."},"597":{"id":"/project/sdk-stability-35","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Keep autocapture disabled by default and document explicit allowlists."},"598":{"id":"/project/sdk-stability-36","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Custom transport behavior"},"599":{"id":"/project/sdk-stability-37","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Custom transports receive the canonical batch payload and own all request semantics."},"600":{"id":"/project/sdk-stability-38","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Document custom transport tests in downstream apps that override delivery."},"601":{"id":"/project/sdk-stability-39","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#decision","content":"No major rewrite is needed before publishing. The highest-risk issues found in this pass were the exposed compression option not being honored, unsafe property serialization, and retry behavior that treated permanent HTTP errors like transient failures. Those have been fixed and covered. The remaining gaps are tradeoffs rather than correctness bugs for this repo's current scope."},"602":{"id":"/reference/api","page_id":"/reference/api","type":"page","content":"API Reference","tags":[],"url":"/reference/api"},"603":{"id":"/reference/api-0","page_id":"/reference/api","tags":[],"type":"text","url":"/reference/api","content":"Rendered OpenAPI reference for the public ingest service."},"604":{"id":"/reference/api-1","page_id":"/reference/api","type":"heading","tags":[],"url":"/reference/api#api-reference","content":"API Reference"},"605":{"id":"/reference/api-2","page_id":"/reference/api","tags":[],"type":"text","url":"/reference/api#api-reference","content":"The formal API reference is generated from `openapi/clickhouse-product-analytics.openapi.yaml`."},"606":{"id":"/reference/api-3","page_id":"/reference/api","tags":[],"type":"text","url":"/reference/api#api-reference","content":"Endpoint pages are generated by Fumadocs OpenAPI under this section. The pr