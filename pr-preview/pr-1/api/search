ication-57","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#deployment-artifact-checks","content":"The CI workflow at `.github/workflows/ci.yml` runs package verification, Docker Compose validation, Helm chart lint/render checks, and the Docker-backed E2E suite. The container workflow at `.github/workflows/container.yml` builds and publishes the ingest image to GitHub Container Registry only after CI succeeds on `main`."},"512":{"id":"/operate/verification-58","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#deployment-artifact-checks","content":"Validate deployment artifacts locally with:"},"513":{"id":"/operate/verification-59","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#deployment-artifact-checks","content":"Run the local ingest benchmark with:"},"514":{"id":"/operate/verification-60","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#deployment-artifact-checks","content":"Package publishability is checked with:"},"515":{"id":"/operate/verification-61","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#when-to-add-e2e-coverage","content":"Add E2E assertions when documentation introduces a new public workflow, API shape, query pattern, or deployment guarantee. Unit tests are enough for internal helpers, but anything shown in `/docs` should either be exercised by `npm run verify:e2e` or explicitly documented as a static/CI-only check."},"516":{"id":"/project/agent-skill","page_id":"/project/agent-skill","type":"page","content":"Coding Agent Skill","breadcrumbs":["Documentation","Project"],"tags":[],"url":"/project/agent-skill"},"517":{"id":"/project/agent-skill-0","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill","content":"Use the repo-local skill to add tracking to applications."},"518":{"id":"/project/agent-skill-1","page_id":"/project/agent-skill","type":"heading","tags":[],"url":"/project/agent-skill#coding-agent-skill","content":"Coding Agent Skill"},"519":{"id":"/project/agent-skill-2","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"This repository includes a Codex-compatible skill at:"},"520":{"id":"/project/agent-skill-3","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"Use it when asking a coding agent to add product analytics tracking to an application. The skill assumes the npm packages are available and guides the agent to:"},"521":{"id":"/project/agent-skill-4","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"find existing analytics conventions before adding new calls,"},"522":{"id":"/project/agent-skill-5","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"choose and initialize the SDK or React provider,"},"523":{"id":"/project/agent-skill-6","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"add stable event names and privacy-safe properties,"},"524":{"id":"/project/agent-skill-7","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"use `identify`, `$set`, and `$set_once` intentionally,"},"525":{"id":"/project/agent-skill-8","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"update or add tests for the tracked user flow,"},"526":{"id":"/project/agent-skill-9","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"avoid sending secrets, tokens, passwords, or high-cardinality payloads."},"527":{"id":"/project/agent-skill-10","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"Example prompt:"},"528":{"id":"/project/agent-skill-11","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"For exact SDK calls, see sending events and the SDK reference. For backend events, see the API reference."},"529":{"id":"/project/publishing","page_id":"/project/publishing","type":"page","content":"Publishing Packages","breadcrumbs":["Documentation","Project"],"tags":[],"url":"/project/publishing"},"530":{"id":"/project/publishing-0","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing","content":"Dry-run and publish the SDK and React packages to npm."},"531":{"id":"/project/publishing-1","page_id":"/project/publishing","type":"heading","tags":[],"url":"/project/publishing#publishing-packages","content":"Publishing Packages"},"532":{"id":"/project/publishing-2","page_id":"/project/publishing","type":"heading","tags":[],"url":"/project/publishing#dry-run","content":"Dry Run"},"533":{"id":"/project/publishing-3","page_id":"/project/publishing","type":"heading","tags":[],"url":"/project/publishing#version-and-release","content":"Version and Release"},"534":{"id":"/project/publishing-4","page_id":"/project/publishing","type":"heading","tags":[],"url":"/project/publishing#registry-prerequisites","content":"Registry Prerequisites"},"535":{"id":"/project/publishing-5","page_id":"/project/publishing","type":"heading","tags":[],"url":"/project/publishing#package-contents","content":"Package Contents"},"536":{"id":"/project/publishing-6","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#publishing-packages","content":"The repository is private at the npm root, but the SDK and React workspaces are publishable public packages:"},"537":{"id":"/project/publishing-7","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#publishing-packages","content":"`@clickhouse-product-analytics/sdk`"},"538":{"id":"/project/publishing-8","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#publishing-packages","content":"`@clickhouse-product-analytics/react`"},"539":{"id":"/project/publishing-9","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#publishing-packages","content":"Both packages are ESM-only. A separate bundling step is not required for normal npm usage because modern application bundlers consume the `exports` map and bundle the package into the host application. Add a bundled artifact only if you want direct `<script>` tag or legacy CommonJS support."},"540":{"id":"/project/publishing-10","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#dry-run","content":"Run the full release dry-run before publishing:"},"541":{"id":"/project/publishing-11","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#dry-run","content":"This command checks package/runtime version alignment, runs typecheck, tests, package builds, generated reference docs, `npm pack --dry-run`, and `npm publish --dry-run` for both public packages."},"542":{"id":"/project/publishing-12","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#version-and-release","content":"Release It is configured for versioning and tagging:"},"543":{"id":"/project/publishing-13","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#version-and-release","content":"Run the release from a clean working tree after the intended files are committed. The release hook updates both package versions, keeps `@clickhouse-product-analytics/react` aligned with the same SDK dependency version, and updates the SDK runtime version exported from `packages/sdk/src/version.ts`."},"544":{"id":"/project/publishing-14","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#version-and-release","content":"The Release It config creates the local commit and tag but keeps `git push` and npm publishing disabled. Review the version bump, then push the release commit and tag explicitly:"},"545":{"id":"/project/publishing-15","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#version-and-release","content":"After the pushed commit and tag are visible, publish explicitly:"},"546":{"id":"/project/publishing-16","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#version-and-release","content":"Use a prerelease version and npm dist tag for unstable releases:"},"547":{"id":"/project/publishing-17","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#registry-prerequisites","content":"Before the first publish, verify that the npm account can publish the `@clickhouse-product-analytics` scope or rename the packages to a scope you control:"},"548":{"id":"/project/publishing-18","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#registry-prerequisites","content":"If the npm account requires two-factor authentication for publishing, add `--otp <code>` to each `npm publish` command. If you publish from GitHub Actions later, decide whether to require npm provenance and use an npm token/OIDC setup that matches that policy; local CLI publishes do not attach GitHub provenance."},"549":{"id":"/project/publishing-19","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"Each public package includes:"},"550":{"id":"/project/publishing-20","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"`dist`: compiled ESM JavaScript, declarations, and source maps."},"551":{"id":"/project/publishing-21","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"`src`: TypeScript source for source-map debugging."},"552":{"id":"/project/publishing-22","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"`README.md`"},"553":{"id":"/project/publishing-23","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"`LICENSE`"},"554":{"id":"/project/publishing-24","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"`THIRD_PARTY_NOTICES.md`"},"555":{"id":"/project/publishing-25","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"`package.json`"},"556":{"id":"/project/publishing-26","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"The ingest service package is marked private because it is deployed as a container rather than published as an npm library."},"557":{"id":"/project/sdk-stability","page_id":"/project/sdk-stability","type":"page","content":"SDK Stability Review","breadcrumbs":["Documentation","Project"],"tags":[],"url":"/project/sdk-stability"},"558":{"id":"/project/sdk-stability-0","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability","content":"Production reliability notes from comparing the SDK with mature browser analytics SDK patterns."},"559":{"id":"/project/sdk-stability-1","page_id":"/project/sdk-stability","type":"heading","tags":[],"url":"/project/sdk-stability#sdk-stability-review","content":"SDK Stability Review"},"560":{"id":"/project/sdk-stability-2","page_id":"/project/sdk-stability","type":"heading","tags":[],"url":"/project/sdk-stability#what-was-reviewed","content":"What Was Reviewed"},"561":{"id":"/project/sdk-stability-3","page_id":"/project/sdk-stability","type":"heading","tags":[],"url":"/project/sdk-stability#improvements-applied","content":"Improvements Applied"},"562":{"id":"/project/sdk-stability-4","page_id":"/project/sdk-stability","type":"heading","tags":[],"url":"/project/sdk-stability#stability-gaps-to-watch","content":"Stability Gaps To Watch"},"563":{"id":"/project/sdk-stability-5","page_id":"/project/sdk-stability","type":"heading","tags":[],"url":"/project/sdk-stability#decision","content":"Decision"},"564":{"id":"/project/sdk-stability-6","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#sdk-stability-review","content":"The browser SDK is intentionally small. This review focuses on performance and stability patterns from mature browser analytics SDKs, not feature parity."},"565":{"id":"/project/sdk-stability-7","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#what-was-reviewed","content":"Mature open-source browser analytics SDK repository structure and package surfaces."},"566":{"id":"/project/sdk-stability-8","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#what-was-reviewed","content":"Retry queue declarations and release notes around retry queue fixes in established analytics SDKs."},"567":{"id":"/project/sdk-stability-9","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#what-was-reviewed","content":"Long-standing unload reliability discussions around `sendBeacon`."},"568":{"id":"/project/sdk-stability-10","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#what-was-reviewed","content":"This repo's SDK queue, transport, storage, autocapture, React wrapper, and E2E coverage."},"569":{"id":"/project/sdk-stability-11","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"Fetch requests use gzip with browser `CompressionStream` when available, and fall back to plain JSON if compression is unavailable or fails."},"570":{"id":"/project/sdk-stability-12","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"SendBeacon unload flushes remain uncompressed because browsers do not let callers attach arbitrary `content-encoding` headers to beacon bodies."},"571":{"id":"/project/sdk-stability-13","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"The E2E test now exercises SDK compression in addition to direct API gzip requests."},"572":{"id":"/project/sdk-stability-14","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"Event properties are sanitized before enqueueing so circular objects and `bigint` values do not crash capture or flush."},"573":{"id":"/project/sdk-stability-15","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"Permanent HTTP errors such as `401` are no longer retried, while `413` responses split a batch before retrying smaller chunks."},"574":{"id":"/project/sdk-stability-16","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"Concurrent flush calls are serialized, and unload flushes include queued retry batches."},"575":{"id":"/project/sdk-stability-17","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"The ingest service no longer logs every successful request by default, which matters for high-throughput browser batch ingestion."},"576":{"id":"/project/sdk-stability-18","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Area"},"577":{"id":"/project/sdk-stability-19","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Current state"},"578":{"id":"/project/sdk-stability-20","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Recommendation"},"579":{"id":"/project/sdk-stability-21","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Durable retry queue"},"580":{"id":"/project/sdk-stability-22","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Retries live in memory and are flushed on unload but are not persisted across reloads."},"581":{"id":"/project/sdk-stability-23","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Keep this for now because the repo scope is small. Add persistent retry storage only if customer apps show loss during flaky network or reload-heavy flows."},"582":{"id":"/project/sdk-stability-24","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Byte-aware batch splitting"},"583":{"id":"/project/sdk-stability-25","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"The SDK limits queue count and server body size, but it does not split batches by encoded byte size before sending."},"584":{"id":"/project/sdk-stability-26","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Add byte-size splitting before supporting very large property payloads or high `flushAt` values."},"585":{"id":"/project/sdk-stability-27","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Navigation-critical events"},"586":{"id":"/project/sdk-stability-28","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Pageleave uses best-effort `sendBeacon`, then fetch fallback if beacon rejects."},"587":{"id":"/project/sdk-stability-29","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"For form submissions or payment handoffs, call `flush()` before navigating when the event is business-critical."},"588":{"id":"/project/sdk-stability-30","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Cross-tab coordination"},"589":{"id":"/project/sdk-stability-31","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Each tab has its own in-memory queue and shared persisted identity state."},"590":{"id":"/project/sdk-stability-32","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Keep as-is until duplicate or ordering issues appear; cross-tab queue ownership adds complexity."},"591":{"id":"/project/sdk-stability-33","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Autocapture privacy"},"592":{"id":"/project/sdk-stability-34","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"The SDK denies obvious sensitive inputs and values, but autocapture remains opt-in."},"593":{"id":"/project/sdk-stability-35","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Keep autocapture disabled by default and document explicit allowlists."},"594":{"id":"/project/sdk-stability-36","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Custom transport behavior"},"595":{"id":"/project/sdk-stability-37","page_id":"/project/sdk-stability","tags":[],"type":"tex