rom `packages/sdk/src/version.ts`."},"548":{"id":"/project/publishing-14","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#version-and-release","content":"The Release It config creates the local commit and tag but keeps `git push` and npm publishing disabled. Review the version bump, then push the release commit and tag explicitly:"},"549":{"id":"/project/publishing-15","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#version-and-release","content":"After the pushed commit and tag are visible, publish explicitly:"},"550":{"id":"/project/publishing-16","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#version-and-release","content":"Use a prerelease version and npm dist tag for unstable releases:"},"551":{"id":"/project/publishing-17","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#registry-prerequisites","content":"Before the first publish, verify that the npm account can publish the `@clickhouse-product-analytics` scope or rename the packages to a scope you control:"},"552":{"id":"/project/publishing-18","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#registry-prerequisites","content":"If the npm account requires two-factor authentication for publishing, add `--otp <code>` to each `npm publish` command. If you publish from GitHub Actions later, decide whether to require npm provenance and use an npm token/OIDC setup that matches that policy; local CLI publishes do not attach GitHub provenance."},"553":{"id":"/project/publishing-19","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"Each public package includes:"},"554":{"id":"/project/publishing-20","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"`dist`: compiled ESM JavaScript, declarations, and source maps."},"555":{"id":"