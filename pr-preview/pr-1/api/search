ate/deployment","type":"heading","tags":[],"url":"/operate/deployment#environment-variables","content":"Environment Variables"},"286":{"id":"/operate/deployment-7","page_id":"/operate/deployment","type":"heading","tags":[],"url":"/operate/deployment#migrations","content":"Migrations"},"287":{"id":"/operate/deployment-8","page_id":"/operate/deployment","type":"heading","tags":[],"url":"/operate/deployment#cors-and-source-validation","content":"CORS and Source Validation"},"288":{"id":"/operate/deployment-9","page_id":"/operate/deployment","type":"heading","tags":[],"url":"/operate/deployment#scaling","content":"Scaling"},"289":{"id":"/operate/deployment-10","page_id":"/operate/deployment","type":"heading","tags":[],"url":"/operate/deployment#clickhouse-version-upgrades","content":"ClickHouse Version Upgrades"},"290":{"id":"/operate/deployment-11","page_id":"/operate/deployment","type":"heading","tags":[],"url":"/operate/deployment#github-pages-docs","content":"GitHub Pages Docs"},"291":{"id":"/operate/deployment-12","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#deployment","content":"The runtime stack is intentionally simple: one stateless ingest service and one ClickHouse database. The browser SDK and React package are built into your application bundle; backend services call the ingest API directly."},"292":{"id":"/operate/deployment-13","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#deployment","content":"For platform-specific deployment examples, see Railway deployment and Helm deployment."},"293":{"id":"/operate/deployment-14","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#local-development","content":"The Compose stack starts:"},"294":{"id":"/operate/deployment-15","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#local-development","content":"ClickHouse on `http://127.0.0.1:8123`"},"295":{"id":"/operate/deployment-16","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#local-development","content":"ingest service on `http://127.0.0.1:8080`"},"296":{"id":"/operate/deployment-17","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#local-development","content":"`docker-compose.yml` pins ClickHouse to `clickhouse/clickhouse-server:26.3.9.8-alpine`, the current 26.3 stable release on the Alpine image track when this project was last verified. Keep this as a concrete version tag instead of `latest` so local development and E2E runs do not drift silently. Older LTS branches can receive newer patch dates, but this repo intentionally tracks the latest stable feature branch for local verification. If you need registry-level reproducibility, pin the image by digest in your deployment manifests."},"297":{"id":"/operate/deployment-18","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#local-development","content":"Run the end-to-end verifier after the stack is healthy:"},"298":{"id":"/operate/deployment-19","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#local-development","content":"Stop the local stack when finished:"},"299":{"id":"/operate/deployment-20","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"Run the ingest service as a container close to ClickHouse. Put it behind a TLS-terminating reverse proxy or load balancer. Browser applications talk to the public HTTPS ingest URL. Backend services can use the same public URL or a private network URL."},"300":{"id":"/operate/deployment-21","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"Recommended production model:"},"301":{"id":"/operate/deployment-22","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"one or more ingest service containers,"},"302":{"id":"/operate/deployment-23","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"shared ClickHouse database on a supported stable or LTS ClickHouse release,"},"303":{"id":"/operate/deployment-24","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"stable `PUBLIC_API_KEYS` when backend or no-origin requests are used,"},"304":{"id":"/operate/deployment-25","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"explicit `ALLOWED_ORIGINS`,"},"305":{"id":"/operate/deployment-26","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"`LOG_LEVEL=warn` or stricter for high-volume traffic,"},"306":{"id":"/operate/deployment-27","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"migrations run manually before deploy,"},"307":{"id":"/operate/deployment-28","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"`MIGRATE_ON_START=false` or omitted in production."},"308":{"id":"/operate/deployment-29","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"The ingest service does not require Redis, Postgres, Kafka, object storage, or a background worker."},"309":{"id":"/operate/deployment-30","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#container-image","content":"`.github/workflows/container.yml` builds `packages/ingest-service/Dockerfile` and publishes the image after CI succeeds for pushes to `main`. The image build uses a pinned Node base-image digest and lockfile-strict `npm ci` installs:"},"310":{"id":"/operate/deployment-31","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#container-image","content":"Use the `sha-<commit>` tag for production rollouts, or the image digest reported by GHCR after the publish job completes. The mutable `latest` tag is useful for quick trials but should not be the rollout target for a stable environment. For the strictest rollout, deploy `ghcr.io/<owner>/<repo>/ingest-service@sha256:<digest>`."},"311":{"id":"/operate/deployment-32","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#container-image","content":"The container publishing workflow runs after the `CI` workflow succeeds on `main`, so the image is gated by package verification, Docker Compose validation, Helm render/lint checks, and Docker-backed E2E tests."},"312":{"id":"/operate/deployment-33","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#clickhouse-cloud","content":"ClickHouse Cloud works with the same ingest service configuration. The service uses the official `@clickhouse/client` package and passes `CLICKHOUSE_URL`, `CLICKHOUSE_USER`, `CLICKHOUSE_PASSWORD`, and `CLICKHOUSE_DATABASE` directly to the client. No code change is required for a Cloud service as long as the URL is the HTTPS endpoint for the ClickHouse HTTP interface."},"313":{"id":"/operate/deployment-34","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#clickhouse-cloud","content":"Use the connection details from the ClickHouse Cloud service connection menu. For the Node.js or HTTPS connection form, the URL usually has this shape:"},"314":{"id":"/operate/deployment-35","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#clickhouse-cloud","content":"Then configure the ingest service the same way you would for a self-hosted production deployment:"},"315":{"id":"/operate/deployment-36","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#clickhouse-cloud","content":"Run migrations from a trusted environment that can reach the ClickHouse Cloud service:"},"316":{"id":"/operate/deployment-37","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#clickhouse-cloud","content":"The browser SDK and React package do not connect to ClickHouse Cloud directly. They should continue to send events to the ingest service `apiHost`; the ingest service is the only component that needs ClickHouse Cloud credentials."},"317":{"id":"/operate/deployment-38","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#environment-variables","content":"Variable"},"318":{"id":"/operate/deployment-39","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#environment-variables","content":"Required"},"319":{"id":"/operate/deployment-40","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#environment-variables","content":"Default"},"320":{"id":"/operate/deployment-41","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#environment-variables","content":"Purpose"},"321":{"id":"/operate/deployment-42","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#environment-variables","content":"`PORT`"},"322":{"id":"/operate/deployment-43","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#environment-variables","content":"no"},"323":{"id":"/operate/deployment-44","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#environment-variables","content":"`8080`"},"324":{"id":"/operate/deployment-45","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#environment-variables","content":"HTTP listen port."},"325":{"id":"/operate/deployment-46","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#environment-variables","content":"`PUBLIC_API_KEYS`"},"326":{"id":"/operate/deployment-47","page_id":"/operate/deployment","tags":[],"type":"text","url":"/opera