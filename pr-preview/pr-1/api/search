ate/deployment","tags":[],"type":"text","url":"/operate/deployment#deployment","content":"For platform-specific deployment examples, see Railway deployment and Helm deployment."},"287":{"id":"/operate/deployment-14","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#local-development","content":"The Compose stack starts:"},"288":{"id":"/operate/deployment-15","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#local-development","content":"ClickHouse on `http://127.0.0.1:8123`"},"289":{"id":"/operate/deployment-16","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#local-development","content":"ingest service on `http://127.0.0.1:8080`"},"290":{"id":"/operate/deployment-17","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#local-development","content":"`docker-compose.yml` pins ClickHouse to `clickhouse/clickhouse-server:26.3.9.8-alpine`, the current 26.3 stable release on the Alpine image track when this project was last verified. Keep this as a concrete version tag instead of `latest` so local development and E2E runs do not drift silently. Older LTS branches can receive newer patch dates, but this repo intentionally tracks the latest stable feature branch for local verification. If you need registry-level reproducibility, pin the image by digest in your deployment manifests."},"291":{"id":"/operate/deployment-18","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#local-development","content":"Run the end-to-end verifier after the stack is healthy:"},"292":{"id":"/operate/deployment-19","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#local-development","content":"Stop the local stack when finished:"},"293":{"id":"/operate/deployment-20","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"Run the ingest service as a container close to ClickHouse. Put it behind a TLS-terminating reverse proxy or load balancer. Browser applications talk to the public HTTPS ingest URL. Backend services can use the same public URL or a private network URL."},"294":{"id":"/operate/deployment-21","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"Recommended production model:"},"295":{"id":"/operate/deployment-22","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"one or more ingest service containers,"},"296":{"id":"/operate/deployment-23","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"shared ClickHouse database on a supported stable or LTS ClickHouse release,"},"297":{"id":"/operate/deployment-24","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"stable `PUBLIC_API_KEYS` when backend or no-origin requests are used,"},"298":{"id":"/operate/deployment-25","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"explicit `ALLOWED_ORIGINS`,"},"299":{"id":"/operate/deployment-26","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"`LOG_LEVEL=warn` or stricter for high-volume traffic,"},"300":{"id":"/operate/deployment-27","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"migrations run manually before deploy,"},"301":{"id":"/operate/deployment-28","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"`MIGRATE_ON_START=false` or omitted in production."},"302":{"id":"/operate/deployment-29","page_id":"/operate/deployment","tags":[],"type":"text","url":"/operate/deployment#production-shape","content":"The ingest service does not 