tifying-users-7","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#reset-on-logout","content":"Reset on Logout"},"642":{"id":"/start/identifying-users-8","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#query-identity-links","content":"Query Identity Links"},"643":{"id":"/start/identifying-users-9","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#practical-rules","content":"Practical Rules"},"644":{"id":"/start/identifying-users-10","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#identifying-users","content":"Product analytics needs to connect anonymous pre-login behavior with known users after signup or login. The browser SDK starts with an anonymous distinct ID. When you know who the user is, call `identify` with a stable user ID."},"645":{"id":"/start/identifying-users-11","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#identifying-users","content":"For exact SDK signatures, see the SDK reference. For backend identity payloads, see the API reference."},"646":{"id":"/start/identifying-users-12","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"Every event has a `distinct_id`. In the browser, the SDK creates one automatically and stores it using the configured persistence layer. Backend events must provide a `distinct_id` directly."},"647":{"id":"/start/identifying-users-13","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"The ingest service resolves each `distinct_id` to a `person_id` globally within the deployment:"},"648":{"id":"/start/identifying-users-14","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"If the distinct ID already exists in `person_distinct_ids`, the existing `person_id` is used."},"649":{"id":"/start/identifying-users-15","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"If it does not exist, a deterministic `person_id` is derived from the distinct ID."},"650":{"id":"/start/identifying-users-16","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"Every accepted event writes or refreshes the event distinct ID in `person_distinct_ids`."},"651":{"id":"/start/identifying-users-17","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"`$identify` and `$create_alias` also link additional anonymous or alias IDs to the same `person_id`."},"652":{"id":"/start/identifying-users-18","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"Use stable database IDs, account IDs, or UUIDs as identified user IDs. Avoid temporary IDs, emails that can change, or values such as `anonymous`, `guest`, `unknown`, `true`, `false`, or `null`."},"653":{"id":"/start/identifying-users-19","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#browser-identify","content":"Call `identify` after login or signup:"},"654":{"id":"/start/identifying-users-20","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#browser-identify","content":"This emits a `$identify` event. If the browser was previously anonymous, the event includes `$anon_distinct_id` so the ingest service can link the old anonymous ID and the new known ID to the same person."},"655":{"id":"/start/identifying-users-21","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#backend-identify","content":"You can identify users through the direct API by sending `$identify`:"},"656":{"id":"/start/identifying-users-22","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#backend-identify","content":"Backend services do not have automatic anonymous browser state. Use backend identify when a server process learns that two IDs should refer to the same person or when you need to update person properties from server-side facts."},"657":{"id":"/start/identifying-users-23","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#person-properties","content":"`$set` overwrites existing properties:"},"658":{"id":"/start/identifying-users-24","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#person-properties","content":"`$set_once` only writes a property if it does not already exist:"},"659":{"id":"/start/identifying-users-25","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#person-properties","content":"The ingest service stores merged person properties in `persons.properties` as a JSON string. Query the latest version with `FINAL`:"},"660":{"id":"/start/identifying-users-26","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#alias","content":"Use `alias` when you need to connect another ID to the same person:"},"661":{"id":"/start/identifying-users-27","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#alias","content":"The SDK emits `$create_alias` with `alias`. The ingest service writes both IDs into `person_distinct_ids` with the same `person_id`."},"662":{"id":"/start/identifying-users-28","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#alias","content":"Direct API form:"},"663":{"id":"/start/identifying-users-29","page_id":"/start/identifying-users","tags":