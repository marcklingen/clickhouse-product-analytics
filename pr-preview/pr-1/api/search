ike:"},"508":{"id":"/operate/verification-56","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#docs-verification","content":"GitHub Pages builds the docs through `.github/workflows/pages.yml` with `npm run docs:build`. Production and preview builds use distinct build-time `NEXT_PUBLIC_DOCS_BASE_PATH` values because Next.js inlines `basePath` during static export. The workflow deploys the production docs for `main` and publishes same-repository PR previews under `/pr-preview/pr-<number>/` when both the PR and its latest push changed docs-related files. Locally, the repo verifies the presence and wiring of docs files during E2E. The actual rendered Pages build is validated by GitHub Actions."},"509":{"id":"/operate/verification-57","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#deployment-artifact-checks","content":"The CI workflow at `.github/workflows/ci.yml` runs package verification, Docker Compose validation, Helm chart lint/render checks, and the Docker-backed E2E suite. The container workflow at `.github/workflows/container.yml` builds and publishes the ingest image to GitHub Container Registry only after CI succeeds on `main`."},"510":{"id":"/operate/verification-58","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#deployment-artifact-checks","content":"Validate deployment artifacts locally with:"},"511":{"id":"/operate/verification-59","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#deployment-artifact-checks","content":"Run the local ingest benchmark with:"},"512":{"id":"/operate/verification-60","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#deployment-artifact-checks","content":"Package publishability is checked with:"},"513":{"id":"/operate/verification-61","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#when-to-add-e2e-coverage","content":"Add E2E assertions when documentation introduces a new public workflow, API shape, query pattern, or deployment guarantee. Unit tests are enough for internal helpers, but anything shown in `/docs` should either be exercised by `npm run verify:e2e` or explicitly documented as a static/CI-only check."},"514":{"id":"/project/agent-skill","page_id":"/project/agent-skill","type":"page","content":"Coding Agent Skill","breadcrumbs":["Documentation","Project"],"tags":[],"url":"/project/agent-skill"},"515":{"id":"/project/agent-skill-0","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill","content":"Use the repo-local skill to add tracking to applications."},"516":{"id":"/project/agent-skill-1","page_id":"/project/agent-skill","type":"heading","tags":[],"url":"/project/agent-skill#coding-agent-skill","content":"Coding Agent Skill"},"517":{"id":"/project/agent-skill-2","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"This repository includes a Codex-compatible skill at:"},"518":{"id":"/project/agent-skill-3","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"Use it when asking a coding agent to add product analytics tracking to an application. The skill assumes the npm packages are available and guides the agent to:"},"519":{"id":"/project/agent-skill-4","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"find existing analytics conventions before adding new calls,"},"520":{"id":"/project/agent-skill-5","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"choose and initialize the SDK or React provider,"},"521":{"id":"/project/agent-skill-6","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"add stable event names and privacy-safe properties,"},"522":{"id":"/project/agent-skill-7","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"use `identify`, `$set`, and `$set_once` intentionally,"},"523":{"id":"/project/agent-skill-8","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"update or add tests for the tracked user flow,"},"524":{"id":"/project/agent-skill-9","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"avoid sending secrets, tokens, passwords, or high-cardinality payloads."},"525":{"id":"/project/agent-skill-10","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"Example prompt:"},"526":{"id":"/project/agent-skill-11","page_id":"/project/agent-skill","tags":[],"type":"text","url":"/project/agent-skill#coding-agent-skill","content":"For exact SDK calls, see sending events and the SDK reference. For backend events, see the API reference."},"527":{"id":"/project/publishing","page_id":"/project/publishing","type":"page","content":"Publishing Packages","breadcrumbs":["Documentation","Project"],"tags":[],"url":"/project/publishing"},"528":{"id":"/project/publishing-0","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing","content":"Dry-run and publish the SDK and React packages to npm."},"529":{"id":"/project/publishing-1","page_id":"/project/publishing","type":"heading","tags":[],"url":"/project/publishing#publishing-packages","content":"Publishing Packages"},"530":{"id":"/project/publishing-2","page_id":"/project/publishing","type":"heading","tags":[],"url":"/project/publishing#dry-run","content":"Dry Run"},"531":{"id":"/project/publishing-3","page_id":"/project/publishing","type":"heading","tags":[],"url":"/project/publishing#version-and-release","content":"Version and Release"},"532":{"id":"/project/publishing-4","page_id":"/project/publishing","type":"heading","tags":[],"url":"/project/publishing#registry-prerequisites","content":"Registry Prerequisites"},"533":{"id":"/project/publishing-5","page_id":"/project/publishing","type":"heading","tags":[],"url":"/project/publishing#package-contents","content":"Package Contents"},"534":{"id":"/project/publishing-6","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#publishing-packages","content":"The repository is private at the npm root, but the SDK and React workspaces are publishable public packages:"},"535":{"id":"/project/publishing-7","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#publishing-packages","content":"`@clickhouse-product-analytics/sdk`"},"536":{"id":"/project/publishing-8","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#publishing-packages","content":"`@clickhouse-product-analytics/react`"},"537":{"id":"/project/publishing-9","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#publishing-packages","content":"Both packages are ESM-only. A separate bundling step is not required for normal npm usage because modern application bundlers consume the `exports` map and bundle the package into the host application. Add a bundled artifact only if you want direct `<script>` tag or legacy CommonJS support."},"538":{"id":"/project/publishing-10","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#dry-run","content":"Run the full release dry-run before publishing:"},"539":{"id":"/project/publishing-11","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#dry-run","content":"This command checks package/runtime version alignment, runs typecheck, tests, package builds, generated reference docs, `npm pack --dry-run`, and `npm publish --dry-run` for both public packages."},"540":{"id":"/project/publishing-12","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#version-and-release","content":"Release It is configured for versioning and tagging:"},"541":{"id":"/project/publishing-13","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#version-and-release","content":"Run the release from a clean working tree after the intended files are committed. The release hook updates both package versions, keeps `@clickhouse-product-analytics/react` aligned with the same SDK dependency version, and updates the SDK runtime version exported from `packages/sdk/src/version.ts`."},"542":{"id":"/project/publishing-14","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#version-and-release","content":"The Release It config creates the local commit and tag but keeps `git push` and npm publishing disabled. Review the version bump, then push the release commit and tag explicitly:"},"543":{"id":"/project/publishing-15","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#version-and-release","content":"After the pushed commit and tag are visible, publish explicitly:"},"544":{"id":"/project/publishing-16","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#version-and-release","content":"Use a prerelease version and npm dist tag for unstable releases:"},"545":{"id":"/project/publishing-17","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#registry-prerequisites","content":"Before the first publish, verify that the npm account can publish the `@clickhouse-product-analytics` scope or rename the packages to a scope you control:"},"546":{"id":"/project/publishing-18","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#registry-prerequisites","content":"If the npm account requires two-factor authentication for publishing, add `--otp <code>` to each `npm publish` command. If you publish from GitHub Actions later, decide whether to require npm provenance and use an npm token/OIDC setup that matches that policy; local CLI publishes do not attach GitHub provenance."},"547":{"id":"/project/publishing-19","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"Each public package includes:"},"548":{"id":"/project/publishing-20","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"`dist`: compiled ESM JavaScript, declarations, and source maps."},"549":{"id":"/project/publishing-21","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"`src`: TypeScript source for source-map debugging."},"550":{"id":"/project/publishing-22","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"`README.md`"},"551":{"id":"/project/publishing-23","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"`LICENSE`"},"552":{"id":"/project/publishing-24","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"`THIRD_PARTY_NOTICES.md`"},"553":{"id":"/project/publishing-25","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"`package.json`"},"554":{"id":"/project/publishing-26","page_id":"/project/publishing","tags":[],"type":"text","url":"/project/publishing#package-contents","content":"The ingest service package is marked private because it is deployed as a container rather than published as an npm library."},"555":{"id":"/project/sdk-stability","page_id":"/project/sdk-stability","type":"page","content":"SDK Stability Review","breadcrumbs":["Documentation","Project"],"tags":[],"url":"/project/sdk-stability"},"556":{"id":"/project/sdk-stability-0","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability","content":"Production reliability notes from comparing the SDK with mature browser analytics SDK patterns."},"557":{"id":"/project/sdk-stability-1","page_id":"/project/sdk-stability","type":"heading","tags":[],"url":"/project/sdk-stability#sdk-stability-review","content":"SDK Stability Review"},"558":{"id":"/project/sdk-stability-2","page_id":"/project/sdk-stability","type":"heading","tags":[],"url":"/project/sdk-stability#what-was-reviewed","content":"What Was Reviewed"},"559":{"id":"/project/sdk-stability-3","page_id":"/project/sdk-stability","type":"heading","tags":[],"url":"/project/sdk-stability#improvements-applied","content":"Improvements Applied"},"560":{"id":"/project/sdk-stability-4","page_id":"/project/sdk-stability","type":"heading","tags":[],"url":"/project/sdk-stability#stability-gaps-to-watch","content":"Stability Gaps To Watch"},"561":{"id":"/project/sdk-stability-5","page_id":"/project/sdk-stability","type":"heading","tags":[],"url":"/project/sdk-stability#decision","content":"Decision"},"562":{"id":"/project/sdk-stability-6","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#sdk-stability-review","content":"The browser SDK is intentionally small. This review focuses on performance and stability patterns from mature browser analytics SDKs, not feature parity."},"563":{"id":"/project/sdk-stability-7","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#what-was-reviewed","content":"Mature open-source browser analytics SDK repository structure and package surfaces."},"564":{"id":"/project/sdk-stability-8","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#what-was-reviewed","content":"Retry queue declarations and release notes around retry queue fixes in established analytics SDKs."},"565":{"id":"/project/sdk-stability-9","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#what-was-reviewed","content":"Long-standing unload reliability discussions around `sendBeacon`."},"566":{"id":"/project/sdk-stability-10","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#what-was-reviewed","content":"This repo's SDK queue, transport, storage, autocapture, React wrapper, and E2E coverage."},"567":{"id":"/project/sdk-stability-11","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"Fetch requests use gzip with browser `CompressionStream` when available, and fall back to plain JSON if compression is unavailable or fails."},"568":{"id":"/project/sdk-stability-12","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"SendBeacon unload flushes remain uncompressed because browsers do not let callers attach arbitrary `content-encoding` headers to beacon bodies."},"569":{"id":"/project/sdk-stability-13","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"The E2E test now exercises SDK compression in addition to direct API gzip requests."},"570":{"id":"/project/sdk-stability-14","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"Event properties are sanitized before enqueueing so circular objects and `bigint` values do not crash capture or flush."},"571":{"id":"/project/sdk-stability-15","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"Permanent HTTP errors such as `401` are no longer retried, while `413` responses split a batch before retrying smaller chunks."},"572":{"id":"/project/sdk-stability-16","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"Concurrent flush calls are serialized, and unload flushes include queued retry batches."},"573":{"id":"/project/sdk-stability-17","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#improvements-applied","content":"The ingest service no longer logs every successful request by default, which matters for high-throughput browser batch ingestion."},"574":{"id":"/project/sdk-stability-18","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Area"},"575":{"id":"/project/sdk-stability-19","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Current state"},"576":{"id":"/project/sdk-stability-20","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Recommendation"},"577":{"id":"/project/sdk-stability-21","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Durable retry queue"},"578":{"id":"/project/sdk-stability-22","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Retries live in memory and are flushed on unload but are not persisted across reloads."},"579":{"id":"/project/sdk-stability-23","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Keep this for now because the repo scope is small. Add persistent retry storage only if customer apps show loss during flaky network or reload-heavy flows."},"580":{"id":"/project/sdk-stability-24","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Byte-aware batch splitting"},"581":{"id":"/project/sdk-stability-25","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"The SDK limits queue count and server body size, but it does not split batches by encoded byte size before sending."},"582":{"id":"/project/sdk-stability-26","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Add byte-size splitting before supporting very large property payloads or high `flushAt` values."},"583":{"id":"/project/sdk-stability-27","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Navigation-critical events"},"584":{"id":"/project/sdk-stability-28","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Pageleave uses best-effort `sendBeacon`, then fetch fallback if beacon rejects."},"585":{"id":"/project/sdk-stability-29","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"For form submissions or payment handoffs, call `flush()` before navigating when the event is business-critical."},"586":{"id":"/project/sdk-stability-30","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Cross-tab coordination"},"587":{"id":"/project/sdk-stability-31","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Each tab has its own in-memory queue and shared persisted identity state."},"588":{"id":"/project/sdk-stability-32","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Keep as-is until duplicate or ordering issues appear; cross-tab queue ownership adds complexity."},"589":{"id":"/project/sdk-stability-33","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Autocapture privacy"},"590":{"id":"/project/sdk-stability-34","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"The SDK denies obvious sensitive inputs and values, but autocapture remains opt-in."},"591":{"id":"/project/sdk-stability-35","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Keep autocapture disabled by default and document explicit allowlists."},"592":{"id":"/project/sdk-stability-36","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Custom transport behavior"},"593":{"id":"/project/sdk-stability-37","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Custom transports receive the canonical batch payload and own all request semantics."},"594":{"id":"/project/sdk-stability-38","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#stability-gaps-to-watch","content":"Document custom transport tests in downstream apps that override delivery."},"595":{"id":"/project/sdk-stability-39","page_id":"/project/sdk-stability","tags":[],"type":"text","url":"/project/sdk-stability#decision","content":"No major rewrite is needed before publishing. The highest-risk issues found in this pass were the exposed compression option not being honored, unsafe property serialization, and retry behavior that treated permanent HTTP errors like transient failures. Those have been fixed and covered. The remaining gaps are tradeoffs rather than correctness bugs for this repo's current scope."},"596":{"id":"/start/identifying-users","page_id":"/start/identifying-users","type":"page","content":"Identifying Users","breadcrumbs":["Documentation","Start"],"tags":[],"url":"/start/identifying-users"},"597":{"id":"/start/identifying-users-0","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users","content":"Anonymous IDs, identify, person properties, aliases, and reset."},"598":{"id":"/start/identifying-users-1","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#identifying-users","content":"Identifying Users"},"599":{"id":"/start/identifying-users-2","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#distinct-ids-and-person-ids","content":"Distinct IDs and Person IDs"},"600":{"id":"/start/identifying-users-3","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#browser-identify","content":"Browser Identify"},"601":{"id":"/start/identifying-users-4","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#backend-identify","content":"Backend Identify"},"602":{"id":"/start/identifying-users-5","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#person-properties","content":"Person Properties"},"603":{"id":"/start/identifying-users-6","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#alias","content":"Alias"},"604":{"id":"/start/identifying-users-7","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#reset-on-logout","content":"Reset on Logout"},"605":{"id":"/start/identifying-users-8","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#query-identity-links","content":"Query Identity Links"},"606":{"id":"/start/identifying-users-9","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#practical-rules","content":"Practical Rules"},"607":{"id":"/start/identifying-users-10","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#identifying-users","content":"Product analytics needs to connect anonymous pre-login behavior with known users after signup or login. The browser SDK starts with an anonymous distinct ID. When you know who the user is, call `identify` with a stable user ID."},"608":{"id":"/start/identifying-users-11","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#identifying-users","content":"For exact SDK signatures, see the SDK reference. For backend identity payloads, see the API reference."},"609":{"id":"/start/identifying-users-12","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"Every event has a `distinct_id`. In the browser, the SDK creates one automatically and stores it using the configured persistence layer. Backend events must provide a `distinct_id` directly."},"610":{"id":"/start/identifying-users-13","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"The ingest service resolves each `distinct_id` to a `person_id` globally within the deployment:"},"611":{"id":"/start/identifying-users-14","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"If the distinct ID already exists in `person_distinct_ids`, the existing `person_id` is used."},"612":{"id":"/start/identifying-users-15","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"If it does not exist, a deterministic `person_id` is derived from the distinct ID."},"613":{"id":"/start/identifying-users-16","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"Every accepted event writes or refreshes the event distinct ID in `person_distinct_ids`."},"614":{"id":"/start/identifying-users-17","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"`$identify` and `$create_alias` also link additional anonymous or alias IDs to the same `person_id`."},"615":{"id":"/start/identifying-users-18","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"Use stable database IDs, account IDs, or UUIDs as identified user IDs. Avoid temporary IDs, emails that can change, or values such as `anonymous`, `guest`, `unknown`, `true`, `false`, or `null`."},"616":{"id":"/start/identifying-users-19","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#browser-identify","content":"Call `identify` after login or signup:"},"617":{"id":"/start/identifying-users-20","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#browser-identify","content":"This emits a `$identify` event. If the browser was previously anonymous, the event includes `$anon_distinct_id` so the ingest service can link the old anonymous ID and the new known ID to the same person."},"618":{"id":"/start/identifying-users-21","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#backend-identify","content":"You can identify users through the direct API by sending `$identify`:"},"619":{"id":"/start/identifying-users-22","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#backend-identify","content":"Backend services do not have automatic anonymous browser state. Use backend identify when a server process learns that two IDs should refer to the same person or when you need to update person properties from server-side facts."},"620":{"id":"/start/identifying-users-23","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#person-properties","content":"`$set` overwrites existing properties:"},"621":{"id":"/start/identifying-users-24","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#person-properties","content":"`$set_once` only writes a property if it does not already exist:"},"622":{"id":"/start/identifying-users-25","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#person-properties","content":"The ingest service stores merged person properties in `persons.properties` as a JSON string. Query the latest version with `FINAL`:"},"623":{"id":"/start/identifying-users-26","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#alias","content":"Use `alias` when you need to connect another ID to the same person:"},"624":{"id":"/start/identifying-users-27","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#alias","content":"The SDK emits `$create_alias` with `alias`. The ingest service writes both IDs into `person_distinct_ids` with the same `person_id`."},"625":{"id":"/start/identifying-users-28","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#alias","content":"Direct API form:"},"626":{"id":"/start/identifying-users-29","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#reset-on-logout","content":"Call `reset()` when a user logs out. This creates a new anonymous distinct ID for future browser events on the same device:"},"627":{"id":"/start/identifying-users-30","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#reset-on-logout","content":"Pass `true` to also reset the device ID:"},"628":{"id":"/start/identifying-users-31","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#query-identity-links","content":"Find all known distinct IDs for a person:"},"629":{"id":"/start/identifying-users-32","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifyin