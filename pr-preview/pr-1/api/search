to-end-verification","content":"The E2E test asserts:"},"478":{"id":"/operate/verification-26","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#end-to-end-verification","content":"ingest and ClickHouse health checks,"},"479":{"id":"/operate/verification-27","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#end-to-end-verification","content":"Fumadocs app files, `content/docs`, OpenAPI spec, generated reference docs, and Pages workflow wiring,"},"480":{"id":"/operate/verification-28","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#end-to-end-verification","content":"Next.js smoke app build,"},"481":{"id":"/operate/verification-29","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#end-to-end-verification","content":"browser SDK custom capture,"},"482":{"id":"/operate/verification-30","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#end-to-end-verification","content":"`capturePageview: \"history_change\"`,"},"483":{"id":"/operate/verification-31","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#end-to-end-verification","content":"`capturePageview: true`,"},"484":{"id":"/operate/verification-32","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#end-to-end-verification","content":"`capturePageview: false`,"},"485":{"id":"/operate/verification-33","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#end-to-end-verification","content":"`capturePageleave: true`,"},"486":{"id":"/operate/verification-34","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/verification#end-to-end-verification","content":"`capturePageleave: \"if_capture_pageview\"`,"},"487":{"id":"/operate/verification-35","page_id":"/operate/verification","tags":[],"type":"text","url":"/operate/v