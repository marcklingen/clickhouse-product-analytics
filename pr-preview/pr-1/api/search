ewport tracking component for React and Next.js applications."},"40":{"id":"/-38","page_id":"/","tags":[],"type":"text","url":"/#scope","content":"`packages/ingest-service`: Fastify ingest API, origin and API-key validation, decompression, normalization, identity side effects, and ClickHouse writes."},"41":{"id":"/-39","page_id":"/","tags":[],"type":"text","url":"/#scope","content":"`packages/ingest-service/migrations`: ClickHouse schema for `events`, `persons`, `person_distinct_ids`, and `sessions`."},"42":{"id":"/-40","page_id":"/","tags":[],"type":"text","url":"/#scope","content":"`examples`: a Next.js browser smoke app and a direct backend capture script."},"43":{"id":"/-41","page_id":"/","tags":[],"type":"text","url":"/#scope","content":"`docs`: this GitHub Pages documentation site, maintained as Markdown."},"44":{"id":"/operate/architecture","page_id":"/operate/architecture","type":"page","content":"Architecture","breadcrumbs":["Documentation","Operate"],"tags":[],"url":"/operate/architecture"},"45":{"id":"/operate/architecture-0","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture","content":"System boundaries, event flow, and identity flow."},"46":{"id":"/operate/architecture-1","page_id":"/operate/architecture","type":"heading","tags":[],"url":"/operate/architecture#architecture","content":"Architecture"},"47":{"id":"/operate/architecture-2","page_id":"/operate/architecture","type":"heading","tags":[],"url":"/operate/architecture#system-boundary","content":"System Boundary"},"48":{"id":"/operate/architecture-3","page_id":"/operate/architecture","type":"heading","tags":[],"url":"/operate/architecture#components","content":"Components"},"49":{"id":"/operate/architecture-4","page_id":"/operate/architecture","type":"heading","tags":[],"url":"/operate/architecture#browser-sdk","content":"Browser SDK"},"50":{"id":"/operate/architecture-5","page_id":"/operate/architecture","type":"heading","tags":[],"url":"/operate/architecture#react-package","content":"React Package"},"51":{"id":"/operate/architecture-6","page_id":"/operate/architecture","type":"heading","tags":[],"url":"/operate/architecture#http-ingest-service","content":"HTTP Ingest Service"},"52":{"id":"/operate/architecture-7","page_id":"/operate/architecture","type":"heading","tags":[],"url":"/operate/architecture#clickhouse","content":"ClickHouse"},"53":{"id":"/operate/architecture-8","page_id":"/operate/architecture","type":"heading","tags":[],"url":"/operate/architecture#event-flow","content":"Event Flow"},"54":{"id":"/operate/architecture-9","page_id":"/operate/architecture","type":"heading","tags":[],"url":"/operate/architecture#identity-flow","content":"Identity Flow"},"55":{"id":"/operate/architecture-10","page_id":"/operate/architecture","type":"heading","tags":[],"url":"/operate/architecture#failure-model","content":"Failure Model"},"56":{"id":"/operate/architecture-11","page_id":"/operate/architecture","type":"heading","tags":[],"url":"/operate/architecture#analysis-model","content":"Analysis Model"},"57":{"id":"/operate/architecture-12","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#architecture","content":"ClickHouse Product Analytics is deliberately small. The browser SDK and direct API collect events, the ingest service validates and normalizes them, and ClickHouse stores the resulting analytics tables. Everything else, including visualization and analysis, happens outside this repository."},"58":{"id":"/operate/architecture-13","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#system-boundary","content":"The ingest service has no settings UI and no runtime project model. Configuration comes from environment variables. Browser traffic is gated by allowed origins. `PUBLIC_API_KEYS` is optional to configure; when configured, keys are required for backend or no-origin requests and optional for allowed-origin browser requests. API keys are not tenant or identity boundaries."},"59":{"id":"/operate/architecture-14","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#browser-sdk","content":"The SDK runs in the browser and owns client-side capture behavior:"},"60":{"id":"/operate/architecture-15","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#browser-sdk","content":"anonymous device and distinct IDs"},"61":{"id":"/operate/architecture-16","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#browser-sdk","content":"local session/window IDs"},"62":{"id":"/operate/architecture-17","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#browser-sdk","content":"custom events"},"63":{"id":"/operate/architecture-18","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#browser-sdk","content":"initial and SPA-route pageviews"},"64":{"id":"/operate/architecture-19","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#browser-sdk","content":"pageleave/unload flushing"},"65":{"id":"/operate/architecture-20","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#browser-sdk","content":"optional autocapture for safe click/change/submit events"},"66":{"id":"/operate/architecture-21","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#browser-sdk","content":"batching, retries, and queue limits"},"67":{"id":"/operate/architecture-22","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#browser-sdk","content":"opt-in/out capture state"},"68":{"id":"/operate/architecture-23","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#browser-sdk","content":"`identify`, `alias`, `reset`, `$set`, and `$set_once`"},"69":{"id":"/operate/architecture-24","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#browser-sdk","content":"The SDK always sends batched payloads to `/batch/`."},"70":{"id":"/operate/architecture-25","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#react-package","content":"The React package wraps the SDK for client-rendered React and Next.js applications:"},"71":{"id":"/operate/architecture-26","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#react-package","content":"`AnalyticsProvider` initializes the SDK in a browser effect."},"72":{"id":"/operate/architecture-27","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#react-package","content":"`useAnalytics()` returns the initialized client when ready and `undefined` before initialization."},"73":{"id":"/operate/architecture-28","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#react-package","content":"`AnalyticsCaptureOnViewed` captures visibility events through `IntersectionObserver` when available, and falls back to immediate capture when it is not."},"74":{"id":"/operate/architecture-29","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#http-ingest-service","content":"The ingest service is a stateless Fastify service. It accepts SDK and direct API traffic at `POST /batch/`, enforces source validation, normalizes event shape, applies identity side effects, and writes to ClickHouse."},"75":{"id":"/operate/architecture-30","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#clickhouse","content":"ClickHouse is the only required database. The service writes append-only events and versioned identity/person rows. Query consumers should treat ClickHouse as the source of truth for product analytics."},"76":{"id":"/operate/architecture-31","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#event-flow","content":"A browser or backend sends a JSON batch payload with one or more events. A one-event batch is the single-event ingestion path."},"77":{"id":"/operate/architecture-32","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#event-flow","content":"The service validates the request source: browser requests must match the origin allowlist, while no-origin backend requests need a configured API key."},"78":{"id":"/operate/architecture-33","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#event-flow","content":"The payload is decoded. Plain JSON request bodies and `Content-Encoding: gzip` request bodies are supported."},"79":{"id":"/operate/architecture-34","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#event-flow","content":"Invalid events inside a batch are dropped when the event name or distinct ID is missing. The response remains successful and includes a `dropped` count."},"80":{"id":"/operate/architecture-35","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#event-flow","content":"Each accepted event is normalized with promoted fields such as `event`, `distinct_id`, `person_id`, `session_id`, `window_id`, `current_url`, `host`, timestamp, IP, and user agent."},"81":{"id":"/operate/architecture-36","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#event-flow","content":"The event distinct ID is recorded in `person_distinct_ids`; identity events also update `persons` and link anonymous or alias IDs."},"82":{"id":"/operate/architecture-37","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#event-flow","content":"Events are inserted into the `events` table."},"83":{"id":"/operate/architecture-38","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#event-flow","content":"The `sessions` view aggregates session-level facts from `events`."},"84":{"id":"/operate/architecture-39","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#identity-flow","content":"Before login, the browser SDK uses an anonymous distinct ID stored through the configured persistence layer. On login or signup, call `identify(userId, properties, setOnceProperties)`. The SDK emits a `$identify` event with the new distinct ID and the previous anonymous ID in `$anon_distinct_id`."},"85":{"id":"/operate/architecture-40","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#identity-flow","content":"The ingest service writes identity links so both IDs point at the same `person_id`. Future events for either ID resolve to that person. Person profile updates are stored in `persons`; `$set` overwrites properties and `$set_once` only fills missing properties."},"86":{"id":"/operate/architecture-41","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#failure-model","content":"The browser SDK queues events and retries transient send failures. During unload/pagehide it uses `sendBeacon` when requested and falls back to `fetch` when the browser rejects the beacon."},"87":{"id":"/operate/architecture-42","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#failure-model","content":"The ingest service has no local runtime state. Horizontal event capture is safe as long as every instance points at the same ClickHouse database and uses the same environment configuration. There is no separate queue, cache, or metadata database in this repository."},"88":{"id":"/operate/architecture-43","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#failure-model","content":"Identity writes use ClickHouse versioned rows. For strict `$set_once` behavior under heavy concurrent identify traffic, use a single identity-writing replica or consistent request routing until that workload has been verified for your deployment."},"89":{"id":"/operate/architecture-44","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#analysis-model","content":"Consumers should query ClickHouse directly:"},"90":{"id":"/operate/architecture-45","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#analysis-model","content":"use `events` for raw event analysis,"},"91":{"id":"/operate/architecture-46","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#analysis-model","content":"use `sessions` for pageview/session questions,"},"92":{"id":"/operate/architecture-47","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#analysis-model","content":"use `persons FINAL` for latest person properties,"},"93":{"id":"/operate/architecture-48","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#analysis-model","content":"use `person_distinct_ids FINAL` for identity lookup."},"94":{"id":"/operate/architecture-49","page_id":"/operate/architecture","tags":[],"type":"text","url":"/operate/architecture#analysis-model","content":"For agentic analytics, prefer narrow SQL queries over exporting tables. See ClickHouse schema for column-level details and query patterns."},"95":{"id":"/operate/clickhouse-schema","page_id":"/operate/clickhouse-schema","type":"page","content":"ClickHouse Schema","breadcrumbs":["Documentation","Operate"],"tags":[],"url":"/operate/clickhouse-schema"},"96":{"id":"/operate/clickhouse-schema-0","page_id":"/operate/clickhouse-schema","tags":[],"type":"text","url":"/operate/clickhouse-schema","content":"Tables, views, and query patterns for humans and agents."},"97":{"id":"/operate/clickhouse-schema-1","page_id":"/operate/clickhouse-schema","type":"heading","tags":[],"url":"/operate/clickhouse-schema#clickhouse-schema","content":"ClickHouse Schema"},"98":{"id":"/operate/clickhouse-schema-2","page_id":"/operate/clickhouse-schema","type":"heading","tags":[],"url":"/operate/clickhouse-schema#schema-map","content":"Schema Map"},"99":{"id":"/operate/clickhouse-schema-3","page_id":"/operate/clickhouse-schema","type":"heading","tags":[],"url":"/operate/clickhouse-schema#agent-query-guidelines","content":"Agent Query Guidelines"},"100":{"id":"/operate/clickhouse-schema-4","page_id":"/operate/clickhouse-schema","type":"heading","tags":[],"url":"/operate/clickhouse-schema#events","content":"`events`"},"101":{"id":"/operate/clickhouse-schema-5","page_id":"/operate/clickhouse-schema","type":"heading","tags":[],"url":"/operate/clickhouse-schema#persons","content":"`persons`"},"102":{"id":"/operate/clickhouse-schema-6","page_id":"/operate/clickhouse-schema","type":"heading","tags":[],"url":"/operate/clickhouse-schema#person_distinct_ids","content":"`person_distinct_ids`"},"103":{"id":"/operate/clickhouse-schema-7","page_id":"/operate/clickhouse-schema","type":"heading","tags":[],"url":"/operate/clickhouse-schema#sessions","content":"`sessions`"},"104":{"id":"/operate/clickhouse-schema-8","page_id":"/operate/clickhouse-schema","type":"heading","tags":[],"url":"/operate/clickhouse-schema#property-access","content":"Property Access"},"105":{"id":"/operate/clickhouse-schema-9","page_id":"/operate/clickhouse-schema","type":"heading","tags":[],"url":"/operate/clickhouse-schema#common-queries","content":"Common Queries"},"106":{"id":"/operate/clickhouse-schema-10","page_id":"/operate/clickhouse-schema","type":"heading","tags":[],"url":"/operate/clickhouse-schema#schema-introspection","content":"Schema Introspection"},"107":{"id":"/operate/clickhouse-schema-11","page_id":"/operate/clickhouse-schema","tags":[],"type":"text","url":"/operate/clickhouse-schema#clickhouse-schema","content":"The ClickHouse database is the analytics source of truth. The default database name is `product_analytics`, but deployments can set `CLICKHOUSE_DATABASE`."},"108":{"id":"/operate/clickhouse-schema-12","page_id":"/operate/clickhouse-schema","tags":[],"type":"text","url":"/operate/clickhouse-schema#clickhouse-schema","content":"There is no project ID and no tenant column. `api_key` is stored on events when supplied as an ingest credential, but it is not a tenant or identity boundary. Do not write queries that assume `project_id`, `team_id`, or multi-tenancy."},"109":{"id":"/operate/clickhouse-schema-13","page_id":"/operate/clickhouse-schema","tags":[],"type":"text","url":"/operate/clickhouse-schema#schema-map","content":"The arrows show write paths, view derivations, and common query joins. They are not ClickHouse foreign-key constraints."},"110":{"id":"/operate/clickhouse-schema-14","page_id":"/operate/clickhouse-schema","tags":[],"type":"text","url":"/operate/clickhouse-schema#agent-query-guidelines","content":"When an agent queries this database:"},"111":{"id":"/operate/clickhouse-schema-15","page_id":"/operate/clickhouse-schema","tags":[],"type":"text","url":"/operate/clickhouse-schema#agent-query-guidelines","content":"Prefer time-bounded queries on `events.timestamp`."},"112":{"id":"/operate/clickhouse-schema-16","page_id":"/operate/clickhouse-schema","tags":[],"type":"text","url":"/operate/clickhouse-schema#agent-query-guidelines","content":"Query `persons FINAL` and `person_distinct_ids FINAL` when you need the latest identity state."},"113":{"id":"/operate/clickhouse-schema-17","page_id":"/operate/clickhouse-schema","tags":[],"type":"text","url":"/operate/clickhouse-schema#agent-query-guidelines","content":"Use `JSONExtractString`, `JSONExtractInt`, `JSONExtractFloat`, `JSONExtractBool`, and `JSONHas` for JSON properties."},"114":{"id":"/operate/clickhouse-schema-18","page_id":"/operate/clickhouse-schema","tags":[],"type":"text","url":"/operate/clickhouse-schema#agent-query-guidelines","content":"Use the `sessions` view for session-level questions instead of rebuilding session aggregation each time."},"115":{"id":"/operate/clickhouse-schema-19","page_id":"/ope