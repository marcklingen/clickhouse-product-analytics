_id":"/reference/openapi","tags":[],"type":"text","url":"/reference/openapi#openapi-spec","content":"Gzip request bodies via `Content-Encoding: gzip`."},"614":{"id":"/reference/openapi-10","page_id":"/reference/openapi","tags":[],"type":"text","url":"/reference/openapi#openapi-spec","content":"Successful ingestion, dropped-event counts, and documented error statuses."},"615":{"id":"/reference/react","page_id":"/reference/react","type":"page","content":"React Reference","breadcrumbs":["Documentation","Reference"],"tags":[],"url":"/reference/react"},"616":{"id":"/reference/react-0","page_id":"/reference/react","tags":[],"type":"text","url":"/reference/react","content":"Generated React package API reference."},"617":{"id":"/reference/react-1","page_id":"/reference/react","type":"heading","tags":[],"url":"/reference/react#react-reference","content":"React Reference"},"618":{"id":"/reference/react-2","page_id":"/reference/react","tags":[],"type":"text","url":"/reference/react#react-reference","content":"The React reference is generated from the TypeScript source comments in `packages/react`."},"619":{"id":"/reference/react-3","page_id":"/reference/react","tags":[],"type":"text","url":"/reference/react#react-reference","content":"Start with the generated React module reference:"},"620":{"id":"/reference/react-4","page_id":"/reference/react","tags":[],"type":"text","url":"/reference/react#react-reference","content":"React module"},"621":{"id":"/reference/react-5","page_id":"/reference/react","tags":[],"type":"text","url":"/reference/react#react-reference","content":"`AnalyticsProvider`"},"622":{"id":"/reference/react-6","page_id":"/reference/react","tags":[],"type":"text","url":"/reference/react#react-reference","content":"`useAnalytics`"},"623":{"id":"/reference/react-7","page_id":"/reference/react","tags":[],"type":"text","url":"/reference/react#react-reference","content":"`AnalyticsCaptureOnViewed`"},"624":{"id":"/reference/react-8","page_id":"/reference/react","tags":[],"type":"text","url":"/reference/react#react-reference","content":"For setup guidance, see React usage."},"625":{"id":"/reference/sdk","page_id":"/reference/sdk","type":"page","content":"SDK Reference","breadcrumbs":["Documentation","Reference"],"tags":[],"url":"/reference/sdk"},"626":{"id":"/reference/sdk-0","page_id":"/reference/sdk","tags":[],"type":"text","url":"/reference/sdk","content":"Generated browser SDK API reference."},"627":{"id":"/reference/sdk-1","page_id":"/reference/sdk","type":"heading","tags":[],"url":"/reference/sdk#sdk-reference","content":"SDK Reference"},"628":{"id":"/reference/sdk-2","page_id":"/reference/sdk","tags":[],"type":"text","url":"/reference/sdk#sdk-reference","content":"The SDK reference is generated from the TypeScript source comments in `packages/sdk`."},"629":{"id":"/reference/sdk-3","page_id":"/reference/sdk","tags":[],"type":"text","url":"/reference/sdk#sdk-reference","content":"Start with the generated SDK module reference:"},"630":{"id":"/reference/sdk-4","page_id":"/reference/sdk","tags":[],"type":"text","url":"/reference/sdk#sdk-reference","content":"SDK module"},"631":{"id":"/reference/sdk-5","page_id":"/reference/sdk","tags":[],"type":"text","url":"/reference/sdk#sdk-reference","content":"`createClient`"},"632":{"id":"/reference/sdk-6","page_id":"/reference/sdk","tags":[],"type":"text","url":"/reference/sdk#sdk-reference","content":"`ClickHouseProductAnalytics`"},"633":{"id":"/reference/sdk-7","page_id":"/reference/sdk","tags":[],"type":"text","url":"/reference/sdk#sdk-reference","content":"`InitOptions`"},"634":{"id":"/reference/sdk-8","page_id":"/reference/sdk","tags":[],"type":"text","url":"/reference/sdk#sdk-reference","content":"For guided usage, see sending events."},"635":{"id":"/start/identifying-users","page_id":"/start/identifying-users","type":"page","content":"Identifying Users","breadcrumbs":["Documentation","Start"],"tags":[],"url":"/start/identifying-users"},"636":{"id":"/start/identifying-users-0","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users","content":"Anonymous IDs, identify, person properties, aliases, and reset."},"637":{"id":"/start/identifying-users-1","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#identifying-users","content":"Identifying Users"},"638":{"id":"/start/identifying-users-2","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#distinct-ids-and-person-ids","content":"Distinct IDs and Person IDs"},"639":{"id":"/start/identifying-users-3","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#browser-identify","content":"Browser Identify"},"640":{"id":"/start/identifying-users-4","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#backend-identify","content":"Backend Identify"},"641":{"id":"/start/identifying-users-5","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#person-properties","content":"Person Properties"},"642":{"id":"/start/identifying-users-6","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#alias","content":"Alias"},"643":{"id":"/start/identifying-users-7","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#reset-on-logout","content":"Reset on Logout"},"644":{"id":"/start/identifying-users-8","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#query-identity-links","content":"Query Identity Links"},"645":{"id":"/start/identifying-users-9","page_id":"/start/identifying-users","type":"heading","tags":[],"url":"/start/identifying-users#practical-rules","content":"Practical Rules"},"646":{"id":"/start/identifying-users-10","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#identifying-users","content":"Product analytics needs to connect anonymous pre-login behavior with known users after signup or login. The browser SDK starts with an anonymous distinct ID. When you know who the user is, call `identify` with a stable user ID."},"647":{"id":"/start/identifying-users-11","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#identifying-users","content":"For exact SDK signatures, see the SDK reference. For backend identity payloads, see the API reference."},"648":{"id":"/start/identifying-users-12","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"Every event has a `distinct_id`. In the browser, the SDK creates one automatically and stores it using the configured persistence layer. Backend events must provide a `distinct_id` directly."},"649":{"id":"/start/identifying-users-13","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"The ingest service resolves each `distinct_id` to a `person_id` globally within the deployment:"},"650":{"id":"/start/identifying-users-14","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"If the distinct ID already exists in `person_distinct_ids`, the existing `person_id` is used."},"651":{"id":"/start/identifying-users-15","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"If it does not exist, a deterministic `person_id` is derived from the distinct ID."},"652":{"id":"/start/identifying-users-16","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"Every accepted event writes or refreshes the event distinct ID in `person_distinct_ids`."},"653":{"id":"/start/identifying-users-17","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"`$identify` and `$create_alias` also link additional anonymous or alias IDs to the same `person_id`."},"654":{"id":"/start/identifying-users-18","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#distinct-ids-and-person-ids","content":"Use stable database IDs, account IDs, or UUIDs as identified user IDs. Avoid temporary IDs, emails that can change, or values such as `anonymous`, `guest`, `unknown`, `true`, `false`, or `null`."},"655":{"id":"/start/identifying-users-19","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#browser-identify","content":"Call `identify` after login or signup:"},"656":{"id":"/start/identifying-users-20","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#browser-identify","content":"This emits a `$identify` event. If the browser was previously anonymous, the event includes `$anon_distinct_id` so the ingest service can link the old anonymous ID and the new known ID to the same person."},"657":{"id":"/start/identifying-users-21","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#backend-identify","content":"You can identify users through the direct API by sending `$identify`:"},"658":{"id":"/start/identifying-users-22","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#backend-identify","content":"Backend services do not have automatic anonymous browser state. Use backend identify when a server process learns that two IDs should refer to the same person or when you need to update person properties from server-side facts."},"659":{"id":"/start/identifying-users-23","page_id":"/start/identifying-users","tags":[],"type":"text","url":"/start/identifying-users#person-properties","content":"`$set` overwrites existing properties: