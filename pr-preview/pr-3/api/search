s, `identify`, `$set`, `$set_once`, aliases, reset, and query implications."},"20":{"id":"/-18","page_id":"/","tags":[],"type":"text","url":"/#start","content":"React usage: provider, hook, and viewport tracking setup for React and Next.js."},"21":{"id":"/-19","page_id":"/","tags":[],"type":"text","url":"/#operate","content":"Architecture: system boundaries, event flow, identity flow, and how the pieces fit together."},"22":{"id":"/-20","page_id":"/","tags":[],"type":"text","url":"/#operate","content":"ClickHouse schema: table/view schemas, JSON property access, and query patterns for humans and agents."},"23":{"id":"/-21","page_id":"/","tags":[],"type":"text","url":"/#deployment","content":"Docker Compose: local stack, ClickHouse Cloud connection details, production container model, environment variables, and migration workflow."},"24":{"id":"/-22","page_id":"/","tags":[],"type":"text","url":"/#deployment","content":"Helm deployment: Kubernetes chart, autoscaling defaults, and install examples."},"25":{"id":"/-23","page_id":"/","tags":[],"type":"text","url":"/#deployment","content":"Railway deployment: Railway container setup with ClickHouse or ClickHouse Cloud."},"26":{"id":"/-24","page_id":"/","tags":[],"type":"text","url":"/#reference","content":"API reference: rendered OpenAPI reference for ingest endpoints."},"27":{"id":"/-25","page_id":"/","tags":[],"type":"text","url":"/#reference","content":"OpenAPI spec: downloadable machine-readable API contract."},"28":{"id":"/-26","page_id":"/","tags":[],"type":"text","url":"/#reference","content":"SDK reference: generated browser SDK reference."},"29":{"id":"/-27","page_id":"/","tags":[],"type":"text","url":"/#reference","content":"React reference: generated React package reference."},"30":{"id":"/-28","page_id":"/","tags":[],"type":"text","url":"/#project","content":"Verification: what `npm run verify` and `npm run verify:e2e` prove."},"31":{"id":"/-29","page_id":"/","tags":[],"type":"text","url":"/#project","content"